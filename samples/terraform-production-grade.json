{
  "terraform": {
    "required_version": ">= 1.5.0",
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      }
    }
  },
  "provider": {
    "aws": [
      {
        "region": "us-east-1"
      }
    ]
  },
  "resource": {
    "aws_kms_key": {
      "main": {
        "description": "Primary KMS key for encryption at rest",
        "enable_key_rotation": true,
        "deletion_window_in_days": 30,
        "tags": {
          "Name": "myapp-main-key",
          "env": "production"
        }
      }
    },
    "aws_secretsmanager_secret": {
      "db_password": {
        "name": "myapp/production/db-password",
        "kms_key_id": "${aws_kms_key.main.arn}",
        "recovery_window_in_days": 30
      }
    },
    "aws_vpc": {
      "main": {
        "cidr_block": "10.0.0.0/16",
        "enable_dns_hostnames": true,
        "enable_dns_support": true,
        "tags": {
          "Name": "myapp-production",
          "env": "production"
        }
      }
    },
    "aws_flow_log": {
      "main": {
        "iam_role_arn": "${aws_iam_role.vpc_flow_log.arn}",
        "log_destination": "${aws_cloudwatch_log_group.vpc_flow_logs.arn}",
        "traffic_type": "ALL",
        "vpc_id": "${aws_vpc.main.id}"
      }
    },
    "aws_subnet": {
      "private_a": {
        "vpc_id": "${aws_vpc.main.id}",
        "cidr_block": "10.0.1.0/24",
        "availability_zone": "us-east-1a",
        "map_public_ip_on_launch": false,
        "tags": { "Name": "private-a", "env": "production" }
      },
      "private_b": {
        "vpc_id": "${aws_vpc.main.id}",
        "cidr_block": "10.0.2.0/24",
        "availability_zone": "us-east-1b",
        "map_public_ip_on_launch": false,
        "tags": { "Name": "private-b", "env": "production" }
      }
    },
    "aws_security_group": {
      "rds": {
        "name": "myapp-rds-sg",
        "description": "RDS access from application layer only",
        "vpc_id": "${aws_vpc.main.id}",
        "ingress": [
          {
            "from_port": 5432,
            "to_port": 5432,
            "protocol": "tcp",
            "security_groups": ["${aws_security_group.app.id}"],
            "cidr_blocks": [],
            "description": "PostgreSQL from app tier only"
          }
        ],
        "egress": [
          {
            "from_port": 0,
            "to_port": 0,
            "protocol": "-1",
            "cidr_blocks": ["10.0.0.0/16"],
            "description": "Internal VPC only"
          }
        ]
      },
      "app": {
        "name": "myapp-app-sg",
        "description": "Application tier security group",
        "vpc_id": "${aws_vpc.main.id}",
        "ingress": [
          {
            "from_port": 443,
            "to_port": 443,
            "protocol": "tcp",
            "cidr_blocks": ["10.0.0.0/16"],
            "description": "HTTPS from internal VPC"
          }
        ],
        "egress": [
          {
            "from_port": 443,
            "to_port": 443,
            "protocol": "tcp",
            "cidr_blocks": ["0.0.0.0/0"],
            "description": "HTTPS outbound for AWS API calls"
          }
        ]
      }
    },
    "aws_db_subnet_group": {
      "main": {
        "name": "myapp-db-subnet-group",
        "subnet_ids": [
          "${aws_subnet.private_a.id}",
          "${aws_subnet.private_b.id}"
        ]
      }
    },
    "aws_db_instance": {
      "main": {
        "identifier": "myapp-production-db",
        "engine": "postgres",
        "engine_version": "16.2",
        "instance_class": "db.t4g.medium",
        "allocated_storage": 100,
        "max_allocated_storage": 500,
        "username": "dbadmin",
        "manage_master_user_password": true,
        "master_user_secret_kms_key_id": "${aws_kms_key.main.arn}",
        "publicly_accessible": false,
        "storage_encrypted": true,
        "kms_key_id": "${aws_kms_key.main.arn}",
        "multi_az": true,
        "backup_retention_period": 14,
        "backup_window": "03:00-04:00",
        "maintenance_window": "mon:04:00-mon:05:00",
        "deletion_protection": true,
        "skip_final_snapshot": false,
        "final_snapshot_identifier": "myapp-production-db-final",
        "performance_insights_enabled": true,
        "performance_insights_kms_key_id": "${aws_kms_key.main.arn}",
        "enabled_cloudwatch_logs_exports": ["postgresql", "upgrade"],
        "vpc_security_group_ids": ["${aws_security_group.rds.id}"],
        "db_subnet_group_name": "${aws_db_subnet_group.main.name}",
        "tags": { "env": "production" }
      }
    },
    "aws_s3_bucket": {
      "app_data": {
        "bucket": "myapp-production-data",
        "tags": { "env": "production" }
      }
    },
    "aws_s3_bucket_versioning": {
      "app_data": {
        "bucket": "${aws_s3_bucket.app_data.id}",
        "versioning_configuration": {
          "status": "Enabled"
        }
      }
    },
    "aws_s3_bucket_server_side_encryption_configuration": {
      "app_data": {
        "bucket": "${aws_s3_bucket.app_data.id}",
        "rule": [
          {
            "apply_server_side_encryption_by_default": {
              "sse_algorithm": "aws:kms",
              "kms_master_key_id": "${aws_kms_key.main.arn}"
            },
            "bucket_key_enabled": true
          }
        ]
      }
    },
    "aws_s3_bucket_public_access_block": {
      "app_data": {
        "bucket": "${aws_s3_bucket.app_data.id}",
        "block_public_acls": true,
        "block_public_policy": true,
        "ignore_public_acls": true,
        "restrict_public_buckets": true
      }
    },
    "aws_s3_bucket_lifecycle_configuration": {
      "app_data": {
        "bucket": "${aws_s3_bucket.app_data.id}",
        "rule": [
          {
            "id": "transition-to-ia",
            "status": "Enabled",
            "transition": [
              { "days": 90, "storage_class": "STANDARD_IA" },
              { "days": 365, "storage_class": "GLACIER" }
            ],
            "expiration": { "days": 2555 }
          }
        ]
      }
    },
    "aws_sqs_queue": {
      "lambda_dlq": {
        "name": "myapp-lambda-dlq",
        "kms_master_key_id": "${aws_kms_key.main.arn}",
        "message_retention_seconds": 1209600
      }
    },
    "aws_lambda_function": {
      "api_handler": {
        "function_name": "myapp-api-handler",
        "role": "${aws_iam_role.lambda_exec.arn}",
        "handler": "index.handler",
        "runtime": "nodejs20.x",
        "filename": "lambda.zip",
        "timeout": 30,
        "memory_size": 512,
        "reserved_concurrent_executions": 100,
        "vpc_config": {
          "subnet_ids": [
            "${aws_subnet.private_a.id}",
            "${aws_subnet.private_b.id}"
          ],
          "security_group_ids": ["${aws_security_group.app.id}"]
        },
        "dead_letter_config": {
          "target_arn": "${aws_sqs_queue.lambda_dlq.arn}"
        },
        "tracing_config": {
          "mode": "Active"
        },
        "environment": {
          "variables": {
            "DB_HOST": "${aws_db_instance.main.address}",
            "BUCKET_NAME": "${aws_s3_bucket.app_data.bucket}",
            "LOG_LEVEL": "info"
          }
        },
        "tags": { "env": "production" }
      }
    },
    "aws_cloudwatch_log_group": {
      "lambda_logs": {
        "name": "/aws/lambda/myapp-api-handler",
        "retention_in_days": 90,
        "kms_key_id": "${aws_kms_key.main.arn}"
      },
      "vpc_flow_logs": {
        "name": "/aws/vpc/myapp-production",
        "retention_in_days": 90,
        "kms_key_id": "${aws_kms_key.main.arn}"
      }
    },
    "aws_cloudwatch_metric_alarm": {
      "lambda_errors": {
        "alarm_name": "myapp-lambda-errors",
        "comparison_operator": "GreaterThanThreshold",
        "evaluation_periods": 2,
        "metric_name": "Errors",
        "namespace": "AWS/Lambda",
        "period": 60,
        "statistic": "Sum",
        "threshold": 5,
        "alarm_description": "Lambda error rate exceeded threshold",
        "dimensions": {
          "FunctionName": "myapp-api-handler"
        },
        "alarm_actions": ["${aws_sns_topic.alerts.arn}"]
      },
      "rds_cpu": {
        "alarm_name": "myapp-rds-high-cpu",
        "comparison_operator": "GreaterThanThreshold",
        "evaluation_periods": 3,
        "metric_name": "CPUUtilization",
        "namespace": "AWS/RDS",
        "period": 300,
        "statistic": "Average",
        "threshold": 80,
        "alarm_description": "RDS CPU utilization above 80%",
        "dimensions": {
          "DBInstanceIdentifier": "myapp-production-db"
        },
        "alarm_actions": ["${aws_sns_topic.alerts.arn}"]
      }
    },
    "aws_sns_topic": {
      "alerts": {
        "name": "myapp-production-alerts",
        "kms_master_key_id": "${aws_kms_key.main.arn}"
      }
    },
    "aws_iam_role": {
      "lambda_exec": {
        "name": "myapp-lambda-exec-role",
        "assume_role_policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Principal\":{\"Service\":\"lambda.amazonaws.com\"},\"Action\":\"sts:AssumeRole\"}]}"
      },
      "vpc_flow_log": {
        "name": "myapp-vpc-flow-log-role",
        "assume_role_policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Principal\":{\"Service\":\"vpc-flow-logs.amazonaws.com\"},\"Action\":\"sts:AssumeRole\"}]}"
      }
    },
    "aws_iam_role_policy": {
      "lambda_s3": {
        "name": "myapp-lambda-s3-policy",
        "role": "${aws_iam_role.lambda_exec.id}",
        "policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Action\":[\"s3:GetObject\",\"s3:PutObject\"],\"Resource\":\"arn:aws:s3:::myapp-production-data/*\"},{\"Effect\":\"Allow\",\"Action\":[\"logs:CreateLogGroup\",\"logs:CreateLogStream\",\"logs:PutLogEvents\"],\"Resource\":\"arn:aws:logs:us-east-1:*:log-group:/aws/lambda/myapp-api-handler:*\"},{\"Effect\":\"Allow\",\"Action\":[\"sqs:SendMessage\"],\"Resource\":\"${aws_sqs_queue.lambda_dlq.arn}\"},{\"Effect\":\"Allow\",\"Action\":[\"secretsmanager:GetSecretValue\"],\"Resource\":\"arn:aws:secretsmanager:us-east-1:*:secret:myapp/production/*\"},{\"Effect\":\"Allow\",\"Action\":[\"kms:Decrypt\"],\"Resource\":\"${aws_kms_key.main.arn}\"},{\"Effect\":\"Allow\",\"Action\":[\"xray:PutTraceSegments\",\"xray:PutTelemetryRecords\"],\"Resource\":\"*\"},{\"Effect\":\"Allow\",\"Action\":[\"ec2:CreateNetworkInterface\",\"ec2:DescribeNetworkInterfaces\",\"ec2:DeleteNetworkInterface\"],\"Resource\":\"*\"}]}"
      }
    },
    "aws_cloudtrail": {
      "main": {
        "name": "myapp-production-trail",
        "s3_bucket_name": "${aws_s3_bucket.app_data.id}",
        "enable_logging": true,
        "is_multi_region_trail": true,
        "enable_log_file_validation": true,
        "include_global_service_events": true,
        "kms_key_id": "${aws_kms_key.main.arn}"
      }
    }
  }
}
