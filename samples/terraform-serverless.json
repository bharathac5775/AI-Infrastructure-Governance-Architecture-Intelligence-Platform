{
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      }
    }
  },
  "provider": {
    "aws": [
      {
        "region": "us-east-1"
      }
    ]
  },
  "resource": {
    "aws_s3_bucket": {
      "uploads": {
        "bucket": "myapp-user-uploads-prod"
      }
    },
    "aws_s3_bucket_versioning": {
      "uploads_versioning": {
        "bucket": "${aws_s3_bucket.uploads.id}",
        "versioning_configuration": {
          "status": "Suspended"
        }
      }
    },
    "aws_lambda_function": {
      "api_handler": {
        "function_name": "myapp-api-handler",
        "role": "${aws_iam_role.lambda_exec.arn}",
        "handler": "index.handler",
        "runtime": "nodejs20.x",
        "filename": "lambda.zip",
        "timeout": 30,
        "memory_size": 512,
        "environment": {
          "variables": {
            "TABLE_NAME": "${aws_dynamodb_table.sessions.name}",
            "BUCKET_NAME": "${aws_s3_bucket.uploads.bucket}",
            "LOG_LEVEL": "info"
          }
        }
      }
    },
    "aws_iam_role": {
      "lambda_exec": {
        "name": "myapp-lambda-exec-role",
        "assume_role_policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Principal\":{\"Service\":\"lambda.amazonaws.com\"},\"Action\":\"sts:AssumeRole\"}]}"
      }
    },
    "aws_iam_role_policy_attachment": {
      "lambda_basic": {
        "role": "${aws_iam_role.lambda_exec.name}",
        "policy_arn": "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
      }
    },
    "aws_api_gateway_rest_api": {
      "main": {
        "name": "myapp-api",
        "description": "Main API Gateway for myapp",
        "endpoint_configuration": {
          "types": ["REGIONAL"]
        }
      }
    },
    "aws_dynamodb_table": {
      "sessions": {
        "name": "myapp-sessions",
        "billing_mode": "PAY_PER_REQUEST",
        "hash_key": "session_id",
        "attribute": [
          {
            "name": "session_id",
            "type": "S"
          }
        ],
        "ttl": {
          "attribute_name": "expires_at",
          "enabled": true
        }
      }
    },
    "aws_cloudwatch_log_group": {
      "lambda_logs": {
        "name": "/aws/lambda/myapp-api-handler"
      }
    }
  }
}
