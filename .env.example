# =============================================================================
# AI Infrastructure Governance Platform — environment configuration
# =============================================================================
# Copy this file to `.env` and edit values for your setup.
# All variables are optional — the platform ships with sensible defaults
# (local Ollama). Cloud providers activate only when you explicitly opt in.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM PROVIDER SELECTION
# -----------------------------------------------------------------------------
# One of: ollama, anthropic, openai, google
# Default: ollama (local, free, runs on your laptop, no data leaves the box).
# Switch by changing this value AND filling in the corresponding API key
# block below. All other agents auto-pick up the new provider — no code change.
LLM_PROVIDER=ollama


# -----------------------------------------------------------------------------
# OLLAMA — local, default
# -----------------------------------------------------------------------------
# Runs entirely on your machine. No API key, no telemetry, no cost.
# Slower than cloud providers (~30s per agent on a M-series Mac with Gemma4).
# Pull the model first:  `ollama pull gemma4:E2B`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:E2B


# -----------------------------------------------------------------------------
# ANTHROPIC (Claude) — cloud
# -----------------------------------------------------------------------------
# To use Claude:
#   1. Get an API key from https://console.anthropic.com/
#   2. Set LLM_PROVIDER=anthropic above
#   3. Uncomment and fill these:
#
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-sonnet-4-5
#
# Suggested models:
#   - claude-sonnet-4-5  (default — fastest + cheapest sonnet tier)
#   - claude-opus-4-7    (highest quality, ~5x cost)
#   - claude-haiku-4-5   (cheapest, fastest, lower quality)


# -----------------------------------------------------------------------------
# OPENAI (GPT) — cloud
# -----------------------------------------------------------------------------
# To use GPT:
#   1. Get an API key from https://platform.openai.com/api-keys
#   2. Set LLM_PROVIDER=openai above
#   3. Uncomment and fill these:
#
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
#
# Optional — override the API endpoint for Azure OpenAI / OpenRouter / proxies:
# OPENAI_BASE_URL=https://your-azure-endpoint.openai.azure.com/openai/deployments/...
#
# Suggested models:
#   - gpt-4o        (default — fast, multimodal, recent)
#   - gpt-4o-mini   (cheapest)
#   - o1            (reasoning-heavy, slower, more expensive)


# -----------------------------------------------------------------------------
# GOOGLE (Gemini) — cloud
# -----------------------------------------------------------------------------
# To use Gemini:
#   1. Get an API key from https://aistudio.google.com/apikey
#   2. Set LLM_PROVIDER=google above
#   3. Uncomment and fill these:
#
# GOOGLE_API_KEY=AIza...
# GOOGLE_MODEL=gemini-1.5-pro
#
# Suggested models:
#   - gemini-1.5-pro    (default — 1M context window, good for big bundles)
#   - gemini-1.5-flash  (cheapest, fastest)


# -----------------------------------------------------------------------------
# Generic LLM tuning (provider-agnostic)
# -----------------------------------------------------------------------------
# Per-call timeout in seconds. Cloud APIs are fast (30–60s is plenty);
# local Ollama on big models can take several minutes — bump if needed.
LLM_TIMEOUT_SECONDS=300


# -----------------------------------------------------------------------------
# Observability (optional — Langfuse)
# -----------------------------------------------------------------------------
# Self-hosted Langfuse for tracing LLM calls. Leave blank to disable.
# LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
# LANGFUSE_SECRET_KEY=your-langfuse-secret-key
# LANGFUSE_HOST=http://localhost:3000
